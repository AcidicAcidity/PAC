# База данных (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow_secret_2026

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SCHEME=tcp

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_2026
