# ============================================
# TaskFlow — Переменные окружения
# Скопируйте этот файл в .env перед запуском
# ============================================

# База данных (PostgreSQL)
DB_HOST=db
DB_PORT=5432
# Порт PostgreSQL на хосте (если 5432 занят локальным Postgres — укажите 5433)
DB_HOST_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow_secret_2026

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# Порт Redis на хосте (если 6379 занят — укажите другой, например 6380)
REDIS_HOST_PORT=6379
REDIS_SCHEME=tcp

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_2026
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Приложение
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# WebSocket
WS_PORT=8080

# Почта (SMTP)
# Для локальной разработки используется Mailpit — письма не уходят в интернет,
# а отображаются в веб-интерфейсе: http://localhost:8025
MAIL_ENABLED=true
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=none
MAIL_FROM=noreply@taskflow.local
MAIL_FROM_NAME=TaskFlow

# Пример для реальной почты (Gmail / Yandex / SendGrid):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=app-password-here
# MAIL_ENCRYPTION=tls
# MAIL_FROM=your@gmail.com
